{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "module": "commonjs",
        "moduleResolution": "bundler",
        "noEmit": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "es6",
    },
    "include": ["./**/*.ts"]
}